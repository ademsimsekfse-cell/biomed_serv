<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Fejox BioServ</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>Fejox BioServ</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	
	<!-- iOS İzinleri - Uygulama Açıklamaları -->
	<key>NSCameraUsageDescription</key>
	<string>Cihaz barkod okuma, QR kod tarama ve belge tarama işlemleri için kamera erişimi gereklidir.</string>
	
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Logo yükleme, belge ekleme ve galeriden görsel seçme işlemleri için fotoğraf galerisi erişimi gereklidir.</string>
	
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Oluşturulan PDF raporları ve belgeleri galeriye kaydetmek için erişim gereklidir.</string>
	
	<key>NSContactsUsageDescription</key>
	<string>Müşteri yetkilisi ekleme ve telefon rehberinden kişi seçme işlemleri için kişiler erişimi gereklidir.</string>
	
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Servis ve bakım kayıtlarında konum bilgisi eklemek için konum erişimi gereklidir.</string>

	<key>NSLocalNetworkUsageDescription</key>
	<string>Fejox BioServ, aynı yerel ağdaki desktop merkez ile servis verilerini senkronize etmek için yerel ağ erişimi kullanır.</string>
	
	<key>NSLocalNotificationUsageDescription</key>
	<string>Bakım hatırlatmaları ve görev bildirimleri için yerel bildirim kullanımı gereklidir.</string>
	
	<!-- Arka Plan Modu - Bildirimler için -->
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>remote-notification</string>
	</array>
	
	<!-- Ağ Güvenliği - HTTP bağlantıları için -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	
	<!-- iPad için Dokunma Optimizasyonu -->
	<key>UIRequiresFullScreen</key>
	<false/>
	
	<!-- Klavye Kısayolları -->
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
</dict>
</plist>
